63","messages":"64","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"32"},{"filePath":"65","messages":"66","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"67","usedDeprecatedRules":"32"},"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\index.js",[],["68","69"],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\App.js",["70"],"import React, { Component, useState } from 'react';\r\nimport De from './components/Formularios/De/De';\r\nimport { BrowserRouter as Router,  Switch, Route } from 'react-router-dom' ;\r\nimport Usuario from './components/Formularios/Usuario/Usuario';\r\nimport Principal from './components/Formularios/Principal/Principal';\r\nimport Navbar from './components/Formularios/Header/Navbar';\r\n\r\nclass App extends Component {        \r\n  render(){\r\n   return (\r\n      <Router>\r\n            <div className='page'>\r\n                <p>\r\n                  <Navbar />  \r\n                  <br/>\r\n                  <hr/>\r\n                  <br/>\r\n                </p>\r\n\r\n              <Switch>\r\n                  <Route path='/De/:id'  component={De} >\r\n                   \r\n                  </Route>\r\n                  <Route path='/About'>\r\n                     <h1>About</h1>\r\n                  </Route> \r\n                  <Route path='/Usuario'>\r\n                  <Usuario/>\r\n                  </Route>                  \r\n                  <Route path='/SignIn'>\r\n                     <h1>SignIn</h1>\r\n                  </Route>       \r\n                  <Route path='/SignUp'>\r\n                     <h1>SignUp</h1>\r\n                  </Route>                                                 \r\n                  <Route exact path='/' >\r\n                    <Principal/>\r\n                  </Route>              \r\n              </Switch>\r\n            </div>\r\n        </Router>\r\n    )\r\n  }\r\n}\r\n\r\nexport default App;","C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Principal\\Principal.js",["71"],"import React, { Component,useState } from 'react';\r\nimport imagenjson from '../../inicial.json';\r\nimport '../Principal/Principal.css';\r\nimport Buscador from '../Buscador/Buscador';\r\nimport Cargaimg from '../Cargarimg/Cargaimg';\r\n\r\n\r\nclass Principal extends Component {\r\n  \r\n  state = {\r\n    tasks : imagenjson,\r\n    garajeName:'',\r\n    termino :' ',\r\n    active:false\r\n  }\r\n\r\n  consultarApi = () => {\r\n    const termino = this.state.termino;\r\n    const url = this.state.tasks.filter(task => task.Nombre === termino) ;    \r\n   // const url =`https://pixabay.com/api/?key=1732750-d45b5378879d1e877cd1d35a6&q=${termino}&per_page=30` ;\r\n\r\n    if (termino==='') {\r\n      this.setState({ tasks : imagenjson })\r\n    }else{\r\n      this.setState({ tasks : url })\r\n    } \r\n  } // fin  consultarApi\r\n  datosBusqueda=(termino)=> {\r\n    this.setState({\r\n      termino\r\n     },()=>{this.consultarApi();\r\n    })\r\n  } \r\n  //------------------------------------------------------------\r\n  render(){\r\n   return (\r\n      <div >\r\n        <div className='head'>\r\n          <Buscador  datosBusqueda={this.datosBusqueda}/>\r\n        </div>    \r\n          <div className='body'>\r\n         {this.state.tasks.map(task => <Cargaimg task={task} />)} \r\n        </div>          \r\n      </div>\r\n     )\r\n  }\r\n}\r\n\r\nexport default Principal;\r\n\r\n","C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Principal\\principal.js",[],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Cargarimg\\Cargaimg.js",["72"],"\r\nimport React, { Component } from 'react';\r\nimport '../Cargarimg/Cargaimg.css';\r\nimport {  Link } from 'react-router-dom' ;\r\nimport De from '../De/De';\r\nlet url=\"\";\r\n\r\n\r\n class Cargaimg extends Component {\r\n    render(){\r\n        return(         \r\n            <Link to={`/De/${this.props.task.Nombre}`}>\r\n                <div className=\"container\" \r\n                    align=\"center\"         \r\n                    id={this.props.task.id}          >\r\n                        <article className='location-listing'>\r\n                            <div className='backgroundTitle'>\r\n                                <p className='titulo-tras'> \r\n                                    <img href={url} className='img-titulo-tras'\r\n                                        src={ this.props.task.Ruta +'/'+ this.props.task.Imagen1 }\r\n                                        alt={this.props.task.Imagen1} />        \r\n                                        {this.props.task.Nombre}                                        \r\n                                </p>\r\n                            </div>\r\n                            <div className='grid' >\r\n                                <img href={url} className='item img-gif-top-left' src={ this.props.task.Ruta +'/'+ this.props.task.Imagen1 } alt={this.props.task.Nombre}/>        \r\n                                <img href={url} className='item img-gif-top-right' src={ this.props.task.Ruta +'/'+ this.props.task.Imagen2} alt={this.props.task.Nombre} />\r\n                                <img href={url} className='item img-gif-left-bottom' src={ this.props.task.Ruta +'/'+ this.props.task.Imagen3} alt={this.props.task.Nombre} />\r\n                                <img href={url} className='item img-gif-right-bottom' src={ this.props.task.Ruta +'/'+ this.props.task.Imagen4} alt={this.props.task.Nombre} />              \r\n                            </div>\r\n                        </article>  \r\n                </div>\r\n            </Link>\r\n\r\n        )\r\n    }\r\n}\r\nexport default Cargaimg;","C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Buscador\\Buscador.js",[],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\CargaImgUser\\CargaImgUser.js",["73","74"],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Header\\Navbar.jsx",[],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\De\\De.js",["75","76"],"import React, { useState,Component } from 'react';\r\nimport Buscador from '../Buscador/Buscador';\r\nimport CargaImgUser from '../CargaImgUser/CargaImgUser';\r\nimport { useParams } from  'react-router-dom' ;\r\nimport useFetch from '../useFetch/useFetch';\r\nimport '../De/De.css';\r\n\r\nconst  De = () => {\r\n  \r\n  const {id} = useParams();\r\n  const url=`https://pixabay.com/api/?key=1732750-d45b5378879d1e877cd1d35a6&q=${id}&per_page=30` ;\r\n\r\n  const res = useFetch(url, {});\r\n  if (!res.response) {\r\n    console.log(res)\r\n    return <div><h1>Loading...</h1></div>\r\n  }\r\n   return (\r\n      <div >\r\n        <div className='head-user'>\r\n          <Buscador  />\r\n        </div>         \r\n        <div className='body-user'>\r\n         {  res.response.hits.map(task => <CargaImgUser task={task} />)};\r\n        </div>\r\n     </div>\r\n     )\r\n  }\r\n\r\n\r\nexport default De\r\n","C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\useFetch\\useFetch.js",["77","78","79"],"import React, { useState,Component } from 'react';\r\n\r\n\r\nconst useFetch = (url, options) => {\r\n    const [response, setResponse] = React.useState(null);\r\n    const [error, setError] = React.useState(null);\r\n    React.useEffect(() => {\r\n      console.log (url);\r\n      const fetchData = async () => {\r\n        try {\r\n          const res = await fetch(url, options);\r\n          const json = await res.json();\r\n          setResponse(json);\r\n        } catch (error) {\r\n          setError(error);\r\n        }\r\n      };\r\n      fetchData();\r\n    }, []);\r\n    return { response, error };\r\n  };\r\n  export default useFetch;","C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\ImgDetalle\\ImgDetalle.js",[],["80","81"],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Portal\\Portal.js",["82","83"],"import React, {Children, Component} from 'react' ;\r\nimport ReactDOM from 'react-dom';\r\n\r\n//const modalRoot= document.getElementById('modal') ;\r\nconst portalRoot = document.getElementById('#portal') ; /* asociado al div portal de index.html */\r\n\r\n\r\nexport default class Modal extends Component {\r\n    constructor(){\r\n        super();\r\n        this.el = document.createElement('div') ;\r\n        alert(\"portal\")\r\n    }\r\n    ComponentDidMount = () => {\r\n        portalRoot.appentChild(this.el)\r\n    }\r\n    ComponentWillUnmount = () => {\r\n        portalRoot.removeChild(this.el);\r\n    }\r\n    render(){\r\n        const {children}=this.props ;\r\n         return ReactDOM.createPortal (children, this.el);\r\n\r\n    }\r\n  \r\n}\r\n",["84","85"],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Modal\\Modal.js",[],"C:\\Users\\Drmu\\Desktop\\tu_trastero\\src\\components\\Formularios\\Usuario\\Usuario.js",["86"],"import React, {Component  } from \"react\";\r\nimport Modal from \"../Modal/Modal\";\r\nimport  \"../Usuario/Usuario.css\";\r\n\r\n\r\nclass Usuario extends Component {\r\n    render(){\r\n        return (\r\n            <div>\r\n                <fieldset class=\"fldset-class\">\r\n                    <legend class=\"legend-class\">Dirección</legend>\r\n                        <div  className='form-group'>\r\n                            <label>Tipo </label>                     \r\n                            <div className=\"form-group-combo\">   \r\n           \r\n                                <span className='tooltiptext'>  Selecione el tipo de Via   </span>\r\n                                <select >\r\n                                    <option value=\"A\">Avenida</option>\r\n                                    <option value=\"B\">Calle</option> \r\n                                    <option value=\"C\">Pasaje</option>\r\n                                </select>\r\n                            </div>\r\n                        </div>                    \r\n\r\n                    \r\n                    <div className=\"form-group\">\r\n                         <label>Nombre</label>\r\n                         <span className='tooltiptext'>  Introduzca Nombre de la Calle / Av. / Pasaje   </span>\r\n                         <input type=\"text\" className=\"input-css\"  tol/>\r\n                    </div>\r\n\r\n                    \r\n                    <div className=\"form-group\">\r\n                        <label>Numero</label>\r\n                        <span className='tooltiptext'>  Introdusca Numero de la dirección   </span>\r\n                         <input type=\"text\" className=\"input-css\" />\r\n                    </div>\r\n                    \r\n                    <div className=\"form-group\">\r\n                         <label>Piso</label>\r\n                         <input type=\"text\" className=\"input-css\" />\r\n                    </div>\r\n                    <p>\r\n                    <div className=\"form-group\">\r\n                         <label>Puerta</label>\r\n                         <input type=\"text\" className=\"input-css\" />\r\n                    </div></p>\r\n                                       \r\n\r\n\r\n\r\n                </fieldset>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n            </div>\r\n        \r\n) }}\r\n\r\n\r\n\r\nexport default Usuario;\r\n",{"ruleId":"87","replacedBy":"88"},{"ruleId":"89","replacedBy":"90"},{"ruleId":"91","severity":1,"message":"92","line":1,"column":28,"nodeType":"93","messageId":"94","endLine":1,"endColumn":36},{"ruleId":"91","severity":1,"message":"92","line":1,"column":27,"nodeType":"93","messageId":"94","endLine":1,"endColumn":35},{"ruleId":"91","severity":1,"message":"95","line":5,"column":8,"nodeType":"93","messageId":"94","endLine":5,"endColumn":10},{"ruleId":"96","severity