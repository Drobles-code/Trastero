* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background-color: rgb(12, 12, 12);
}

.head {
  background-color: rgb(12, 12, 12);
  width: 100%;
}

.body {
  background-color: rgb(12, 12, 12);
  padding-bottom: 80px;
  padding: 20px 0;
  padding-left: 20px;
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 20px;
}
.footer {
    position:fixed;
    left:0px;
    bottom:0px;
    height:30px;
    width:100%;
    background:#999;
}